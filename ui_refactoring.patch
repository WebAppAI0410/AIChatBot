+
+const QuotaWarningBanner: React.FC<QuotaWarningBannerProps> = ({
+  quotaType,
+  percentRemaining,
+  onUpgrade,
+  onDismiss,
+}) => {
+  const colors = useColors();
+  
+  const getQuotaTypeLabel = () => {
+    switch (quotaType) {
