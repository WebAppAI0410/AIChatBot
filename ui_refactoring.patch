+#### 開発モード・本番モードのプラン切替
+開発モードと本番モードでのプラン切替機能を実装します。開発モードではタップ1つで即時切替を可能にし、本番モードでは適切な決済処理を実装します。
+
+##### 開発モード実装
+- `screens/SettingsScreen.tsx` - 開発モード用の簡易プラン切替UI
+  ```typescript
+  // screens/SettingsScreen.tsx (開発モード部分)
+  import React from 'react';
+  import { View, Text, TouchableOpacity, StyleSheet } from 'react-native';
+  import { useStore } from '../store';
+  import { PLANS } from '../constants/plans';
+  import theme from '../ui/theme';
+
+  const DevPlanSwitcher = () => {
+    const { plan, setPlan, updateQuotaLimits } = useStore();
+    
+    // 開発モードでのプラン切替処理
+    const switchPlan = (newPlan: string) => {
+      setPlan(newPlan);
+      updateQuotaLimits();
+      // 開発モードではレシート検証をスキップ
+    };
+    
+    return (
+      <View style={styles.container}>
+        <Text style={styles.title}>開発モード: プラン切替</Text>
+        
+        {Object.entries(PLANS).map(([planId, planData]) => (
+          <TouchableOpacity
+            key={planId}
+            style={[
+              styles.planButton,
+              plan === planId && styles.activePlan
+            ]}
+            onPress={() => switchPlan(planId)}
+          >
+            <Text style={[
+              styles.planText,
+              plan === planId && styles.activePlanText
+            ]}>
+              {planData.name}
+            </Text>
+          </TouchableOpacity>
+        ))}
+        
+        <Text style={styles.note}>
+          ※開発モードでは支払い処理をスキップします
+        </Text>
+      </View>
+    );
+  };
+  
+  const styles = StyleSheet.create({
+    container: {
+      marginVertical: theme.spacing.lg,
