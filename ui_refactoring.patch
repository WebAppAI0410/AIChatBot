+    } else {
+      return `${quotaLabel}の月間クォータが残り${percentRemaining}%です。プランをアップグレードして制限を増やしましょう。`;
+    }
+  };
+  
+  return (
+    <View style={[
+      styles.container,
+      theme.componentStyles.quotaWarning.container,
+    ]}>
+      <View style={styles.iconContainer}>
